{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/upsert-schema.json",
  "title": "DatabaseSchema",
  "description": "Validates the upsert validation schema YAML (converted to JSON for validation)",
  "type": "object",
  "required": ["dialect", "schema", "validation", "tables"],
  "additionalProperties": false,
  "properties": {

    "dialect": {
      "type": "string",
      "description": "Target SQL dialect",
      "enum": ["postgresql"]
    },

    "schema": {
      "type": "string",
      "description": "Default database schema namespace",
      "pattern": "^[A-Za-z0-9_]+$"
    },

    "rootDataPath": {
      "type": "string",
      "description": "Base directory for resolving data file paths; relative to the schema file's directory"
    },

    "validation": {
      "type": "object",
      "description": "Global validation configuration",
      "required": ["defaultNullable"],
      "additionalProperties": false,
      "properties": {
        "defaultNullable": {
          "type": "boolean",
          "description": "If true, columns are nullable unless a required constraint is present"
        },
        "strictFields": {
          "type": "boolean",
          "default": false,
          "description": "If true, unknown fields in data files cause validation failure"
        }
      }
    },

    "tables": {
      "type": "array",
      "description": "List of table definitions",
      "minItems": 1,
      "items": { "$ref": "#/$defs/TableSchema" }
    }
  },

  "$defs": {

    "TableSchema": {
      "type": "object",
      "required": ["tableName", "primaryKey", "columns"],
      "additionalProperties": false,
      "properties": {
        "tableName": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_]+$"
        },
        "description": {
          "type": "string"
        },
        "files": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "List of data file paths for this table, resolved relative to rootDataPath"
        },
        "primaryKey": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" },
          "description": "List of column names that form the primary key"
        },
        "onConflict": {
          "$ref": "#/$defs/OnConflictConfig"
        },
        "columns": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/ColumnSchema" }
        }
      }
    },

    "OnConflictConfig": {
      "type": "object",
      "required": ["target", "action"],
      "additionalProperties": false,
      "properties": {
        "target": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" },
          "description": "Column(s) used in ON CONFLICT (...) clause"
        },
        "action": {
          "type": "string",
          "enum": ["update", "doNothing"],
          "description": "DO UPDATE or DO NOTHING on conflict"
        },
        "excludeFromUpdate": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Columns never overwritten when a conflict update fires"
        }
      }
    },

    "ColumnSchema": {
      "type": "object",
      "required": ["name", "datatype"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_]+$"
        },
        "datatype": {
          "type": "string",
          "description": "SQL type string e.g. VARCHAR(30), INTEGER, NUMERIC(8,2)",
          "pattern": "^[A-Z]+(?:\\([0-9]+(,[0-9]+)?\\))?$"
        },
        "default": {
          "$ref": "#/$defs/DefaultValue"
        },
        "foreignKey": {
          "$ref": "#/$defs/ForeignKeyConfig"
        },
        "constraints": {
          "type": "array",
          "items": { "$ref": "#/$defs/ColumnConstraint" },
          "default": []
        }
      }
    },

    "DefaultValue": {
      "type": "object",
      "required": ["kind", "value"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["LITERAL", "FUNCTION", "EXPRESSION", "GENERATOR"],
          "description": "LITERAL = quoted value, FUNCTION = unquoted SQL function, EXPRESSION = raw SQL, GENERATOR = built-in generator"
        },
        "value": {
          "type": "string",
          "description": "The literal value, function name, SQL expression, or built-in generator"
        },
        "args": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Optional arguments passed to a FUNCTION type default"
        }
      }
    },

    "ForeignKeyConfig": {
      "type": "object",
      "required": ["table", "columns"],
      "additionalProperties": false,
      "properties": {
        "schema": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_]+$",
          "description": "Schema qualifier — inherits top-level schema if omitted"
        },
        "table": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_]+$"
        },
        "columns": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "onUpdate": {
          "$ref": "#/$defs/ForeignKeyAction"
        },
        "onDelete": {
          "$ref": "#/$defs/ForeignKeyAction"
        }
      }
    },

    "ForeignKeyAction": {
      "type": "string",
      "enum": ["cascade", "setNull", "setDefault", "restrict", "noAction"],
      "description": "PostgreSQL referential action — defaults to noAction if omitted"
    },

    "ColumnConstraint": {
      "type": "object",
      "required": ["constraint"],
      "properties": {
        "constraint": {
          "type": "string",
          "enum": ["REQUIRED", "UNIQUE", "ENUM", "PATTERN", "TEMPORAL"]
        },
        "message": {
          "type": "string",
          "description": "Human-readable message shown when this constraint fails"
        }
      },
      "allOf": [
        {
          "if":   { "properties": { "constraint": { "const": "UNIQUE" } } },
          "then": {
            "properties": {
              "conflictTarget": {
                "type": "boolean",
                "default": false,
                "description": "If true, this constraint drives the ON CONFLICT target clause"
              }
            }
          }
        },
        {
          "if":   { "properties": { "constraint": { "const": "ENUM" } } },
          "then": {
            "required": ["values"],
            "properties": {
              "values": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string" },
                "description": "Allowed values — data value must be one of these"
              }
            }
          }
        },
        {
          "if":   { "properties": { "constraint": { "const": "PATTERN" } } },
          "then": {
            "required": ["regex"],
            "properties": {
              "regex": {
                "type": "string",
                "description": "Regular expression the column value must match"
              }
            }
          }
        },
        {
          "if":   { "properties": { "constraint": { "const": "TEMPORAL" } } },
          "then": {
            "properties": {
              "notFuture": {
                "type": "boolean",
                "default": false,
                "description": "If true, rejects timestamps after validation runtime"
              },
              "notPast": {
                "type": "string",
                "pattern": "^-P(?:\\d+Y)?(?:\\d+M)?(?:\\d+D)?$",
                "description": "ISO 8601 negative duration — e.g. -P4Y means no older than 4 years"
              }
            }
          }
        }
      ]
    }
  }
}
