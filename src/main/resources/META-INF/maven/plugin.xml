<?xml version="1.0" encoding="UTF-8"?>
<plugin>
    <name>Knoppen</name>
    <description>Generates SQL from YAML/JSON/CSV data files against a declared schema</description>
    <groupId>org.austindroids</groupId>
    <artifactId>knoppen</artifactId>
    <version>@version@</version>
    <goalPrefix>knoppen</goalPrefix>

    <mojos>

        <mojo>
            <goal>generateSQL</goal>
            <description>Validate the schema and data files, then generate and write SQL upsert statements.</description>
            <requiresDirectInvocation>false</requiresDirectInvocation>
            <requiresProject>true</requiresProject>
            <phase>generate-sources</phase>
            <implementation>org.austindroids.knoppen.mojos.GenerateMojo</implementation>
            <language>java</language>
            <instantiationStrategy>per-lookup</instantiationStrategy>
            <parameters>
                <parameter>
                    <name>schemaFile</name>
                    <type>java.io.File</type>
                    <required>false</required>
                    <editable>true</editable>
                    <description>The schema YAML file describing the tables and their data files.</description>
                </parameter>
                <parameter>
                    <name>strict</name>
                    <type>boolean</type>
                    <required>false</required>
                    <editable>true</editable>
                    <description>Override validation.strictFields from the schema (reject unknown fields when true).</description>
                </parameter>
                <parameter>
                    <name>rootDataPath</name>
                    <type>java.io.File</type>
                    <required>false</required>
                    <editable>true</editable>
                    <description>Override the rootDataPath declared in the schema YAML.</description>
                </parameter>
                <parameter>
                    <name>rootOutputPath</name>
                    <type>java.io.File</type>
                    <required>false</required>
                    <editable>true</editable>
                    <description>Override the rootOutputPath declared in the schema YAML.</description>
                </parameter>
                <parameter>
                    <name>outputFormat</name>
                    <type>java.lang.String</type>
                    <required>false</required>
                    <editable>true</editable>
                    <description>SQL layout preset: LEGACY, SINGLE_LINE, TRADITIONAL, CASCADE2, CASCADE4, RIVER.</description>
                </parameter>
                <parameter>
                    <name>debug</name>
                    <type>boolean</type>
                    <required>false</required>
                    <editable>true</editable>
                    <description>Raise console logging to DEBUG (Maven itself uses -X).</description>
                </parameter>
                <parameter>
                    <name>skip</name>
                    <type>boolean</type>
                    <required>false</required>
                    <editable>true</editable>
                    <description>Skip execution of this goal.</description>
                </parameter>
            </parameters>
            <configuration>
                <schemaFile implementation="java.io.File" default-value="${project.basedir}/src/main/resources/schema.yaml">${knoppen.schema}</schemaFile>
                <strict implementation="boolean" default-value="true">${knoppen.strict}</strict>
                <rootDataPath implementation="java.io.File">${knoppen.rootDataPath}</rootDataPath>
                <rootOutputPath implementation="java.io.File">${knoppen.rootOutputPath}</rootOutputPath>
                <outputFormat implementation="java.lang.String" default-value="LEGACY">${knoppen.outputFormat}</outputFormat>
                <debug implementation="boolean" default-value="false">${knoppen.debug}</debug>
                <skip implementation="boolean" default-value="false">${knoppen.skip}</skip>
            </configuration>
        </mojo>

        <mojo>
            <goal>validate</goal>
            <description>Validate the schema and its declared data files without generating any SQL.</description>
            <requiresDirectInvocation>false</requiresDirectInvocation>
            <requiresProject>true</requiresProject>
            <phase>validate</phase>
            <implementation>org.austindroids.knoppen.mojos.ValidateMojo</implementation>
            <language>java</language>
            <instantiationStrategy>per-lookup</instantiationStrategy>
            <parameters>
                <parameter>
                    <name>schemaFile</name>
                    <type>java.io.File</type>
                    <required>false</required>
                    <editable>true</editable>
                    <description>The schema YAML file describing the tables and their data files.</description>
                </parameter>
                <parameter>
                    <name>strict</name>
                    <type>boolean</type>
                    <required>false</required>
                    <editable>true</editable>
                    <description>Override validation.strictFields from the schema (reject unknown fields when true).</description>
                </parameter>
                <parameter>
                    <name>rootDataPath</name>
                    <type>java.io.File</type>
                    <required>false</required>
                    <editable>true</editable>
                    <description>Override the rootDataPath declared in the schema YAML.</description>
                </parameter>
                <parameter>
                    <name>rootOutputPath</name>
                    <type>java.io.File</type>
                    <required>false</required>
                    <editable>true</editable>
                    <description>Override the rootOutputPath declared in the schema YAML.</description>
                </parameter>
                <parameter>
                    <name>outputFormat</name>
                    <type>java.lang.String</type>
                    <required>false</required>
                    <editable>true</editable>
                    <description>SQL layout preset: LEGACY, SINGLE_LINE, TRADITIONAL, CASCADE2, CASCADE4, RIVER.</description>
                </parameter>
                <parameter>
                    <name>debug</name>
                    <type>boolean</type>
                    <required>false</required>
                    <editable>true</editable>
                    <description>Raise console logging to DEBUG (Maven itself uses -X).</description>
                </parameter>
                <parameter>
                    <name>skip</name>
                    <type>boolean</type>
                    <required>false</required>
                    <editable>true</editable>
                    <description>Skip execution of this goal.</description>
                </parameter>
            </parameters>
            <configuration>
                <schemaFile implementation="java.io.File" default-value="${project.basedir}/src/main/resources/schema.yaml">${knoppen.schema}</schemaFile>
                <strict implementation="boolean" default-value="true">${knoppen.strict}</strict>
                <rootDataPath implementation="java.io.File">${knoppen.rootDataPath}</rootDataPath>
                <rootOutputPath implementation="java.io.File">${knoppen.rootOutputPath}</rootOutputPath>
                <outputFormat implementation="java.lang.String" default-value="LEGACY">${knoppen.outputFormat}</outputFormat>
                <debug implementation="boolean" default-value="false">${knoppen.debug}</debug>
                <skip implementation="boolean" default-value="false">${knoppen.skip}</skip>
            </configuration>
        </mojo>
    </mojos>
</plugin>
